# Copy this to .env.production on the VPS (in the same directory as
# docker-compose.prod.yml) and fill in real values. Never commit the real file.

NODE_ENV=production
PORT=3000

# Service names from docker-compose.prod.yml — not localhost.
MONGODB_URI=mongodb://mongo:27017/chat_app?replicaSet=rs0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=30d
COOKIE_SECRET=change-me-cookie-secret

# Wherever the frontend ends up (e.g. https://your-app.vercel.app). Required —
# the app won't boot without it, and it must exactly match the frontend's origin.
CORS_ORIGIN=https://your-frontend-origin.example

# Local-disk storage (default) — persisted via the uploads_data volume.
STORAGE_DRIVER=local
LOCAL_STORAGE_DIR=./uploads-data
# Must be the public HTTPS URL this API is reachable at (matches PUBLIC_HOSTNAME below).
PUBLIC_API_URL=https://your-vps-public-ip.nip.io

# coturn isn't deployed alongside this stack yet. These are required for the
# app to boot (TURN credential signing), but until a real coturn instance is
# running at TURN_URLS, calls will only succeed over direct P2P (no NAT
# traversal fallback) — fine for same-network testing, not for general use.
TURN_SECRET=change-me-turn-secret
TURN_URLS=stun:stun.l.google.com:19302
TURN_CREDENTIAL_TTL_SECONDS=300

# Used by the Caddyfile ({$PUBLIC_HOSTNAME}) for automatic HTTPS.
# <vps-ip-with-dashes>.nip.io, e.g. 203-0-113-10.nip.io for 203.0.113.10.
# Swap to a real domain later by changing only this line.
PUBLIC_HOSTNAME=your-vps-public-ip.nip.io
