NODE_ENV=development
PORT=3000

MONGODB_URI=mongodb://localhost:27017/chat_app

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=30d

COOKIE_SECRET=change-me-cookie-secret

CORS_ORIGIN=http://localhost:3001

# STORAGE_DRIVER=local works with zero extra setup (saves to LOCAL_STORAGE_DIR,
# served back through this same API). Set STORAGE_DRIVER=s3 to use MinIO/S3/R2 instead.
STORAGE_DRIVER=local
LOCAL_STORAGE_DIR=./uploads-data
PUBLIC_API_URL=http://localhost:3000

# Only required when STORAGE_DRIVER=s3
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=chat-app-media
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
# S3_PUBLIC_ENDPOINT=https://cdn.example.com

# coturn shared-secret (turnserver.conf: use-auth-secret + static-auth-secret=<this value>)
TURN_SECRET=change-me-turn-secret
TURN_URLS=stun:localhost:3478,turn:localhost:3478
TURN_CREDENTIAL_TTL_SECONDS=300

# PUSH_DRIVER=console just logs push payloads (default, zero setup). Set
# PUSH_DRIVER=fcm to actually deliver to the mobile app — requires a Firebase
# service account key (Firebase console > Project settings > Service accounts
# > Generate new private key), pasted here as one JSON string.
PUSH_DRIVER=console
# FCM_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
